# Load Balancer Configuration File
# Edit these values to configure the simulation

# Task processing time range (in clock cycles)
minTaskTime = 10
maxTaskTime = 100

# Number of cycles to wait between adding/removing servers
waitCycles = 5

# Percentage chance (0-100) to generate a new request each cycle
requestGenerationChance = 15

# Blocked IP ranges (prefix matching for firewall/DOS prevention)
# Add multiple lines with blockedIPRange for multiple ranges
blockedIPRange = 192.168.1.
blockedIPRange = 10.0.0.
blockedIPRange = 172.
